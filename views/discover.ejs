<!DOCTYPE html>
<html>
  <head>
    <title>Spotify</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="wrapper">
      <%- include('partials/sidebar') %>

      <div class="right discover-page">
        <%- include('partials/header') %>
        <div class="content-wrapper">
          <main class="main-content">
            <!-- Top Buttons -->
            <div class="filter-buttons">
              <button class="filter-btn active" data-filter="music">Music</button>
              <button class="filter-btn" data-filter="edm">EDM</button>
              <button class="filter-btn" data-filter="indie">Indie</button>
              <button class="filter-btn" data-filter="pop">Pop</button>
              <button class="filter-btn" data-filter="rock">Rock</button>
              <button class="filter-btn" data-filter="alt-rock">Alt Rock</button>
              <button class="filter-btn" data-filter="country">Country</button>
              <button class="filter-btn" data-filter="r&b">R&B</button>
              <button class="filter-btn" data-filter="hip-hop">Hip-Hop</button>
              <button class="filter-btn" data-filter="podcasts">Podcast</button>
              <button class="filter-btn" data-filter="audiobooks">Audiobooks</button>
            </div>
            <section class="hero-section">
              <% data.songs.forEach((song, index) => { %>
              <div
                class="hero-slide"
                data-index="<%= index %>"
                data-colour="<%= song.color %>"
                data-src="<%= song.audio || '' %>"
              >
                <div class="hero-left">
                  <div class="hero-image-wrapper">
                    <img src="<%= song.cover %>" alt="<%= song.title %>" class="hero-image" />

                    <div class="progress-bar">
                      <div class="progress"></div>
                    </div>
                  </div>
                </div>

                <div class="hero-right">
                  <div class="info-card">
                    <div class="info-left">
                      <img src="<%= song.image %>" alt="<%= song.author %>" class="artist-image" />
                    </div>

                    <div class="info-right">
                      <h2 class="title"><%= song.title %></h2>

                      <div class="info-right-desc">
                        <p><span class="by-text">By </span><span class="Spotify"><%= song.author %></span></p>
                        <p>·</p>
                        <p class="info-right-year"><%= song.year %></p>
                        <p>·</p>
                        <p class="info-right-Duration"><%= song.duration %></p>
                      </div>

                      <div class="player-controls">
                        <svg class="player-icon play-icon" viewBox="0 0 39 39" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="19.0085" cy="19.0085" r="19.0085" fill="#1ED760" />
                          <path
                            d="M24.6336 17.6825C25.6541 18.2716 25.6541 19.7446 24.6336 20.3337L17.3454 24.5416C16.325 25.1308 15.0494 24.3943 15.0494 23.2159L15.0494 14.8003C15.0494 13.6219 16.325 12.8855 17.3454 13.4746L24.6336 17.6825Z"
                            fill="black"
                          />
                        </svg>

                        <svg
                          class="player-icon pause-icon"
                          viewBox="0 0 39 39"
                          xmlns="http://www.w3.org/2000/svg"
                          style="display: none"
                        >
                          <circle cx="19.0085" cy="19.0085" r="19.0085" fill="#1ED760" />
                          <path
                            d="M15.8398 14.2559V23.7601"
                            stroke="black"
                            stroke-width="3.16809"
                            stroke-linecap="round"
                          />
                          <path
                            d="M22.1758 14.2559V23.7601"
                            stroke="black"
                            stroke-width="3.16809"
                            stroke-linecap="round"
                          />
                        </svg>
                        <div class="profile-icon-mobile">
                          <img src="<%= song.image %>" alt="<%= song.author %>" />
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="12" cy="12" r="5.5" fill="#E0E0E0" stroke="#E0E0E0" />
                            <path
                              d="M14.5515 11.991H11.9902M9.42895 11.991H11.9902M11.9902 11.991L11.9902 9.42969M11.9902 11.991V14.5523"
                              stroke="#060606"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                        </div>
                        <button class="favorite">
                          <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg">
                            <path
                              d="M12.3242 12.4017V28.7055C12.3242 29.6489 13.3906 30.1977 14.1582 29.6493L19.0949 26.1232C19.9014 25.5471 20.9849 25.5471 21.7915 26.1232L26.7281 29.6493C27.4958 30.1977 28.5621 29.6489 28.5621 28.7055V12.4017C28.5621 11.1206 27.5236 10.082 26.2424 10.082H14.6439C13.3628 10.082 12.3242 11.1206 12.3242 12.4017Z"
                              stroke="#898989"
                              stroke-width="2.3197"
                            />
                          </svg>
                          <p>500k</p></button
                        ><svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
                          <rect
                            width="20"
                            height="20"
                            rx="3"
                            transform="matrix(1 0 0 -1 9.82715 31.3301)"
                            stroke="#898989"
                            stroke-width="2"
                            stroke-linejoin="round"
                          />
                          <path
                            d="M11.8271 11.3301H27.8271C27.8271 9.67322 26.484 8.33008 24.8271 8.33008H14.8271C13.1703 8.33008 11.8271 9.67322 11.8271 11.3301Z"
                            stroke="#898989"
                            stroke-width="1.5"
                            stroke-linejoin="round"
                          />
                          <path
                            d="M15.8271 21.3301H19.8271M23.8271 21.3301H19.8271M19.8271 21.3301V17.3301M19.8271 21.3301V25.3301"
                            stroke="#898989"
                            stroke-width="2.02054"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                        <svg class="adjust" viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg">
                          <path
                            d="M19.3632 11.7871H14.5924C13.0426 11.7871 11.7861 13.0435 11.7861 14.5934C11.7861 16.1433 13.0426 17.3997 14.5924 17.3997H19.3632"
                            stroke="#898989"
                            stroke-width="2.3573"
                            stroke-linecap="round"
                          />
                          <path
                            d="M11.7861 23.0117L28.624 23.0117"
                            stroke="#898989"
                            stroke-width="2.3573"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                          <path
                            d="M11.7861 28.625L28.624 28.625"
                            stroke="#898989"
                            stroke-width="2.3573"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                          <path
                            d="M23.5732 14.3128H26.0989M28.6246 14.3128H26.0989M26.0989 14.3128V11.7871M26.0989 14.3128V16.8385"
                            stroke="#898989"
                            stroke-width="2.02054"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                        <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg">
                          <path
                            d="M20.6897 22.0162V10.7401M20.6897 10.7401L16.0466 15.3832M20.6897 10.7401L25.3328 15.3832M28.981 20.358V25.0011C28.981 26.4664 27.7931 27.6543 26.3278 27.6543L15.0516 27.6543C13.5863 27.6543 12.3984 26.4664 12.3984 25.0011V20.358"
                            stroke="#898989"
                            stroke-width="2.02054"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                        <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="11.7863" cy="20.2072" r="1.68378" fill="#898989" />
                          <circle cx="20.2053" cy="20.2072" r="1.68378" fill="#898989" />
                          <circle cx="28.6242" cy="20.2072" r="1.68378" fill="#898989" />
                        </svg>
                      </div>

                      <div class="genre-buttons">
                        <% song.genres.forEach(genre => { %>
                        <button class="genre-btn"><%= genre %></button>
                        <% }) %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <% }) %>
            </section>
          </main>
          <%- include('partials/friends') %>
        </div>
        <%- include('partials/player') %>
      </div>
    </div>
    <script src="/js/script.js"></script>
    <script src="/js/discover.js"></script>
  </body>
</html>
