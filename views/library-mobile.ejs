<!DOCTYPE html>
<html>
  <head>
    <!-- Page metadata and global styles -->
    <title>Spotify</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Main stylesheet -->
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="wrapper">
      <%# Sidebar navigation (shared across pages) %>
      <%- include('partials/sidebar') %>
      <div class="right">
        <%# Top header with navigation and actions %>
        <%- include('partials/header') %>
        <div class="content-wrapper">
          <%# Main content area for homepage %>
          <main class="main-content">
            <%# Search bar section %>
            <div class="search">
              <div class="search-box">
                <input type="text" placeholder="Search Library" />
                <svg class="small-svg" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M22.1492 21.8208C23.4966 20.4463 24.3274 18.5637 24.3274 16.4869C24.3274 12.2787 20.9159 8.86719 16.7076 8.86719C12.4994 8.86719 9.08789 12.2787 9.08789 16.4869C9.08789 20.6952 12.4994 24.1067 16.7076 24.1067C18.8392 24.1067 20.7663 23.2314 22.1492 21.8208ZM22.1492 21.8208L26.6133 26.3926"
                    stroke="#898989"
                    stroke-opacity="0.5"
                    stroke-width="1.77054"
                    stroke-linecap="round"
                  />
                </svg>
              </div>
              <%# Add button (plus icon) %>
              <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M20.5 11V30 M11 20.5H30"
                  stroke="#898989"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
            <%# Mobile library filter buttons %>
            <div class="mobile-library-wrapper">
              <div class="library-filter">
                <%# Group button %>
                <button>
                  <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg">
                    <path d="M29.3351 14.081L11.3351 14.081" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                    <path d="M25.8273 20.081H15.8273" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                    <path d="M22.8273 26.081H18.8273" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                  </svg>
                  <span>Group</span>
                </button>
                <%# Recents button %>
                <button>
                  <span>Recents</span>
                  <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16.584 26.3301H28.584" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                    <path d="M11 26.3301H12" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                    <path d="M16.584 20.3301H28.584" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                    <path d="M11 20.3301H12" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                    <path d="M16.584 14.3301H28.584" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                    <path d="M11 14.3301H12" stroke="#898989" stroke-width="2" stroke-linecap="round" />
                  </svg>
                </button>
              </div>

              <%# Mobile sidebar %>
              <section class="mobile-sidebar"><%- include('partials/sidebar') %></section>
            </div>
          </main>
        </div>
      </div>
      <%# Bottom music player %>
      <%- include('partials/player') %>
    </div>
    <%# Main client-side JavaScript %>
    <script src="/js/script.js"></script>
  </body>
</html>
