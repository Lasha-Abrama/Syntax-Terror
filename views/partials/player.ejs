<footer class="player">
  <!-- Left Zone: Track Info -->
  <div class="player-left">
    <img src="album-cover.jpg" alt="Album Cover" class="track-cover" />
    <div class="track-info">
      <span class="track-title">Track Title</span>
      <span class="track-artist">Artist Name</span>
    </div>
    <div class="track-actions">
      <button class="like-btn">❤️</button>
      <button class="more-btn">⋯</button>
    </div>
  </div>

  <!-- Center Zone: Playback Controls -->
  <div class="player-center">
    <div class="playback-controls">
      <button class="prev-btn">⏮️</button>
      <button class="play-pause-btn">▶️</button>
      <button class="next-btn">⏭️</button>
    </div>
    <div class="progress-bar">
      <span class="time current">0:00</span>
      <div class="progress-track">
        <div class="progress-filled"></div>
      </div>
      <span class="time total">3:45</span>
    </div>
  </div>

  <!-- Right Zone: Actions -->
  <div class="player-right">
    <button class="queue-btn">📃</button>
    <button class="device-btn">💻</button>
    <div class="volume-control">
      <span>🔊</span>
      <div class="volume-slider">
        <div class="volume-filled"></div>
      </div>
    </div>
  </div>
</footer>
