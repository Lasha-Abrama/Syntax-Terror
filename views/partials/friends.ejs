<!-- 
  Set the section title; default is "Friends Activity" if no `title` is passed
 -->
<% const sectionTitle = typeof title !== 'undefined' ? title : "Friends Activity"; %>

<section class="friends-section" id="friendsPanel">
  <!-- Section header with title and icons -->
  <div class="friends-section-title">
    <p><%= sectionTitle %></p>
    <!-- Add / Close icons for the friends panel -->
    <div class="friends-section-title-icons">
      <!-- Add friend icon -->
      <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg" id="friends-add">
        <path
          d="M23.5711 13.4691C23.5711 15.329 22.0634 16.8367 20.2035 16.8367C18.3436 16.8367 16.8359 15.329 16.8359 13.4691C16.8359 11.6093 18.3436 10.1016 20.2035 10.1016C22.0634 10.1016 23.5711 11.6093 23.5711 13.4691Z"
          stroke="#898989"
          stroke-width="2.02054"
        />
        <path
          d="M16.8365 20.2051L13.2847 22.5729C12.3479 23.1975 11.7852 24.249 11.7852 25.3749V27.0525C11.7852 27.9204 12.4888 28.624 13.3567 28.624H26.0973"
          stroke="#898989"
          stroke-width="2.02054"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M23.5723 21.0472H26.0979M28.6236 21.0472H26.0979M26.0979 21.0472V18.5215M26.0979 21.0472V23.5728"
          stroke="#898989"
          stroke-width="2.02054"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <!-- Close / X icon for hiding friends panel -->
      <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg" id="friends-close">
        <path
          d="M25.257 15.1543L20.2056 20.2056M15.1543 25.257L20.2056 20.2056M20.2056 20.2056L15.1543 15.1543M20.2056 20.2056L25.257 25.257"
          stroke="#898989"
          stroke-width="2.02054"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </div>
  </div>
  <!-- Friends activity list -->
  <div class="friend-activity">
    <!-- Active friend currently listening -->
    <div class="friend active-now">
      <img src="./assets/images/profiles/friend1.png" alt="friend-profile" />
      <div class="friend-content">
        <p class="friend-content-title">FriendlyMusicListener</p>
        <div class="friend-content-activity">
          <!-- Listening bars icon -->
          <svg class="listening-svg" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M10.418 20.323V16.24M14.8722 20.323V9.55859M19.3265 20.323V13.6417"
              stroke="#1ED760"
              stroke-width="1.48475"
              stroke-linecap="round"
            />
          </svg>
          <div>
            <p class="friend-content-activity-song">Goosebumps</p>
            <p>·</p>
            <p class="friend-content-activity-desc">Travis Scott</p>
          </div>
        </div>
      </div>
    </div>
    <!-- Another active friend -->
    <div class="friend active-now">
      <img src="./assets/images/profiles/friend2.png" alt="friend-profile" />
      <div class="friend-content">
        <p class="friend-content-title">AverageMusicEnjoyer</p>
        <div class="friend-content-activity">
          <svg class="listening-svg" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M10.418 20.323V16.24M14.8722 20.323V9.55859M19.3265 20.323V13.6417"
              stroke="#1ED760"
              stroke-width="1.48475"
              stroke-linecap="round"
            />
          </svg>
          <div>
            <p class="friend-content-activity-song">Get Lucky</p>
            <p>·</p>
            <p class="friend-content-activity-desc">Daft Punk</p>
          </div>
        </div>
      </div>
    </div>
    <!-- Friend who is not currently active -->
    <div class="friend not-active">
      <img src="./assets/images/profiles/friend3.png" alt="friend-profile" />
      <div class="friend-content">
        <p class="friend-content-title">MusicEnthusiast</p>
        <div class="friend-content-activity">
          <p class="friend-content-activity-desc">1h</p>
          <p class="friend-content-activity-song">would he</p>
          <p>·</p>
          <p class="friend-content-activity-desc">joji</p>
        </div>
      </div>
    </div>
    <!-- Another inactive friend -->
    <div class="friend not-active">
      <img src="./assets/images/profiles/friend4.png" alt="friend-profile" />
      <div class="friend-content">
        <p class="friend-content-title">IListenToMusic56</p>
        <div class="friend-content-activity">
          <p class="friend-content-activity-desc">6h</p>
          <p class="friend-content-activity-song">Rockstar</p>
          <p>·</p>
          <p class="friend-content-activity-desc">Post Malone</p>
        </div>
      </div>
    </div>
  </div>
</section>
