<!DOCTYPE html>
<html>
  <head>
    <title>Spotify</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  </head>
  <body>
    <div class="wrapper">
      <%- include('partials/sidebar') %>

      <div class="right">
        <%- include('partials/header') %>
        <div class="content-wrapper">
          <main class="main-content">
            <div class="home-buttons">
              <!-- Top Buttons -->
              <div class="filter-buttons">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="music">Music</button>
                <button class="filter-btn" data-filter="artists">Artists</button>
                <button class="filter-btn" data-filter="audiobooks">Audiobooks</button>
                <button class="filter-btn" data-filter="podcasts">Podcasts</button>
                <button class="filter-btn" data-filter="episodes">Episodes</button>
              </div>
              <svg viewBox="0 0 41 41" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M19.8262 13.0859H12.8262C11.7216 13.0859 10.8262 13.9814 10.8262 15.0859C10.8262 16.1905 11.7216 17.0859 12.8262 17.0859H19.8262"
                  stroke="#898989"
                  stroke-width="2"
                  stroke-linecap="round"
                />
                <rect
                  x="23.5957"
                  y="12.0859"
                  width="6.23077"
                  height="6.23077"
                  rx="3.11538"
                  stroke="#898989"
                  stroke-width="2"
                />
                <path
                  d="M20.8262 27.3164L27.8262 27.3164C28.9307 27.3164 29.8262 26.421 29.8262 25.3164C29.8262 24.2118 28.9307 23.3164 27.8262 23.3164L20.8262 23.3164"
                  stroke="#898989"
                  stroke-width="2"
                  stroke-linecap="round"
                />
                <rect
                  x="17.0566"
                  y="28.3164"
                  width="6.23077"
                  height="6.23077"
                  rx="3.11538"
                  transform="rotate(-180 17.0566 28.3164)"
                  stroke="#898989"
                  stroke-width="2"
                />
              </svg>
            </div>
            <section class="mobile-section">
              <% let combined = []; let maxLength = Math.min(6, data.songs.length + data.mixes.length); let songsCopy =
              [...data.songs]; let mixCopy = [...data.mixes]; while (combined.length < maxLength && (songsCopy.length >
              0 || mixCopy.length > 0)) { if (songsCopy.length > 0) { combined.push({ type: 'song', item:
              songsCopy.shift() }); } if (combined.length >= maxLength) break; if (mixCopy.length > 0) { combined.push({
              type: 'mix', item: mixCopy.shift() }); } } %> <% combined.forEach(card => { %>
              <div class="mobile-card">
                <img src="<%= card.item.image %>" alt="<%= card.item.title %>" />
                <% if (card.type === 'song') { %>
                <div class="mobile-card-info">
                  <p class="title"><%= card.item.title %></p>
                  <p class="mobile-card-author"><%= card.item.author %></p>
                </div>
                <% } else { %>
                <p class="mobile-title-center"><%= card.item.title %></p>
                <% } %>
              </div>
              <% }) %>
            </section>

            <!-- Made For You Section -->
            <section class="section" data-category="music">
              <div class="section-title">
                <h3>Made for you</h3>
                <%- include('partials/actions', {type : 'homepage'}) %>
              </div>
              <div class="cards-viewport">
                <div class="card-container">
                  <% data.mixes.slice(0,12).forEach(item => { %>
                  <%- include('partials/card', { item, type: 'mix' }) %>
                  <% }) %>
                </div>
              </div>
            </section>
            <!-- Your Top Mixes Section -->
            <section class="section" data-category="music">
              <div class="section-title">
                <h3>Your top mixes</h3>
                <%- include('partials/actions', {type : 'homepage'}) %>
              </div>

              <div class="cards-viewport">
                <div class="card-container">
                  <% data.mixes.slice(12,20).forEach(item => { %>
                  <%- include('partials/card', { item, type: 'mix' }) %>
                  <% }) %>
                </div>
              </div>
            </section>
            <!-- Your Favorite Artists Section -->
            <section class="section" data-category="artists">
              <div class="section-title">
                <h3>Your favorite artists</h3>
                <%- include('partials/actions', {type : 'homepage'}) %>
              </div>
              <div class="cards-viewport">
                <div class="card-container">
                  <% data.artists.forEach(item => { %>
                  <%- include('partials/card', { item, type: 'artist' }) %>
                  <% }) %>
                </div>
              </div>
            </section>
            <!-- Your Albums Section -->
            <section class="section" data-category="music">
              <div class="section-title">
                <h3>Albums for You</h3>
                <%- include('partials/actions', {type : 'homepage'}) %>
              </div>
              <div class="cards-viewport">
                <div class="card-container">
                  <% data.albums.forEach(item => { %>
                  <%- include('partials/card', { item, type: 'album' }) %>
                  <% }) %>
                </div>
              </div>
            </section>
            <!-- Your Audiobooks Section -->
            <section class="section" data-category="audiobooks">
              <div class="section-title">
                <h3>Audiobooks for you</h3>
                <%- include('partials/actions', {type : 'homepage'}) %>
              </div>
              <div class="cards-viewport">
                <div class="card-container">
                  <% data.audiobooks.forEach(item => { %>
                  <%- include('partials/card', { item, type: 'audiobooks' }) %>
                  <% }) %>
                </div>
              </div>
            </section>
            <!-- Your Podcasts Section -->
            <section class="section" data-category="podcasts">
              <div class="section-title">
                <h3>Podcasts for you</h3>
                <%- include('partials/actions', {type : 'homepage'}) %>
              </div>
              <div class="cards-viewport">
                <div class="card-container">
                  <% data.podcasts.forEach(item => { %>
                  <%- include('partials/card', { item, type: 'podcasts' }) %>
                  <% }) %>
                </div>
              </div>
            </section>
            <!-- Your Episodes Section -->
            <section class="section" data-category="episodes">
              <div class="section-title">
                <h3>Episodes for you</h3>
                <%- include('partials/actions', {type : 'homepage'}) %>
              </div>
              <div class="cards-viewport">
                <div class="card-container">
                  <% data.podcasts.forEach(item => { %>
                  <%- include('partials/card', { item, type: 'episodes' }) %>
                  <% }) %>
                </div>
              </div>
            </section>
          </main>
          <%- include('partials/friends') %>
        </div>
        <%- include('partials/player') %>
      </div>
    </div>
    <script src="/js/script.js"></script>
  </body>
</html>
