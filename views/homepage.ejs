<!DOCTYPE html>
<html>
  <head>
    <title>Spotify</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>
  <body>
    <div class="wrapper">
      <%- include('partials/sidebar') %>

      <div class="right">
        <%- include('partials/header') %>

        <main class="main-content">
          <!-- Top Buttons -->
          <div class="filter-buttons">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="music">Music</button>
            <button class="filter-btn" data-filter="podcasts">Podcasts</button>
            <button class="filter-btn" data-filter="audiobooks">
              Audiobooks
            </button>
          </div>

          <!-- Made For You Section -->
          <section class="section top-mixes">
            <div class="section-title">
              <h3>Made For You</h3>
              <div class="section-actions">
                <button class="arrow arrow-left">
                  <svg
                    width="41"
                    height="41"
                    viewBox="0 0 41 41"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <g opacity="0.5">
                      <path
                        d="M27.7832 20.2064H13.471M13.471 20.2064L19.3643 26.0996M13.471 20.2064L19.3643 14.3131"
                        stroke="#898989"
                        stroke-width="2.02054"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </g>
                  </svg>
                </button>
                <button class="arrow arrow-right">
                  <svg
                    width="41"
                    height="41"
                    viewBox="0 0 41 41"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <g opacity="0.5">
                      <path
                        d="M13.4688 20.2057H27.7809M27.7809 20.2057L21.8877 14.3125M27.7809 20.2057L21.8877 26.099"
                        stroke="#898989"
                        stroke-width="2.02054"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </g>
                  </svg>
                </button>
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 40 40"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <circle
                    cx="11.7853"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                  <circle
                    cx="20.2053"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                  <circle
                    cx="28.6232"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                </svg>
              </div>
            </div>

            <div class="cards-viewport">
              <div class="card-container">
                <% data.mixes.slice(0,12).forEach(item => { %>
                <%- include('partials/card', { item, type: 'mix' }) %>
                <% }) %>
              </div>
            </div>
          </section>

          <!-- Your Top Mixes Section -->
          <section class="section top-mixes">
            <div class="section-title">
              <h3>Your Top Mixes</h3>
              <div class="section-actions">
                <button class="arrow arrow-left">
                  <svg
                    width="41"
                    height="41"
                    viewBox="0 0 41 41"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <g opacity="0.5">
                      <path
                        d="M27.7832 20.2064H13.471M13.471 20.2064L19.3643 26.0996M13.471 20.2064L19.3643 14.3131"
                        stroke="#898989"
                        stroke-width="2.02054"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </g>
                  </svg>
                </button>
                <button class="arrow arrow-right">
                  <svg
                    width="41"
                    height="41"
                    viewBox="0 0 41 41"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <g opacity="0.5">
                      <path
                        d="M13.4688 20.2057H27.7809M27.7809 20.2057L21.8877 14.3125M27.7809 20.2057L21.8877 26.099"
                        stroke="#898989"
                        stroke-width="2.02054"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </g>
                  </svg>
                </button>
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 40 40"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <circle
                    cx="11.7853"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                  <circle
                    cx="20.2053"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                  <circle
                    cx="28.6232"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                </svg>
              </div>
            </div>

            <div class="cards-viewport">
              <div class="card-container">
                <% data.mixes.slice(12,20).forEach(item => { %>
                <%- include('partials/card', { item, type: 'mix' }) %>
                <% }) %>
              </div>
            </div>
          </section>

          <!-- Your Favorite Artists Section -->
          <section class="section favorite-artists">
            <div class="section-title">
              <h3>Your Favorite Artists</h3>
              <div class="section-actions">
                <button class="arrow arrow-left">
                  <svg
                    width="41"
                    height="41"
                    viewBox="0 0 41 41"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <g opacity="0.5">
                      <path
                        d="M27.7832 20.2064H13.471M13.471 20.2064L19.3643 26.0996M13.471 20.2064L19.3643 14.3131"
                        stroke="#898989"
                        stroke-width="2.02054"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </g>
                  </svg>
                </button>
                <button class="arrow arrow-right">
                  <svg
                    width="41"
                    height="41"
                    viewBox="0 0 41 41"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <g opacity="0.5">
                      <path
                        d="M13.4688 20.2057H27.7809M27.7809 20.2057L21.8877 14.3125M27.7809 20.2057L21.8877 26.099"
                        stroke="#898989"
                        stroke-width="2.02054"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </g>
                  </svg>
                </button>
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 40 40"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <circle
                    cx="11.7853"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                  <circle
                    cx="20.2053"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                  <circle
                    cx="28.6232"
                    cy="20.2072"
                    r="1.68378"
                    fill="#898989"
                  />
                </svg>
              </div>
            </div>
            <div class="cards-viewport">
              <div class="card-container">
                <% data.artists.forEach(item => { %>
                <%- include('partials/card', { item, type: 'artist' }) %>
                <% }) %>
              </div>
            </div>
          </section>
          <section class="section favorite-artists">
            <h3>Albums For You</h3>
            <div class="card-container">
              <% data.albums.forEach(item => { %>
              <%- include('partials/card', {
              item, type: 'album' }) %>
              <% }) %>
            </div>
          </section>
        </main>
      </div>
    </div>

    <%- include('partials/player') %>

    <script>
      document.querySelectorAll(".section").forEach((section) => {
        const container = section.querySelector(".card-container");
        const viewport = section.querySelector(".cards-viewport");
        const leftBtn = section.querySelector(".arrow-left");
        const rightBtn = section.querySelector(".arrow-right");

        if (!container || !leftBtn || !rightBtn) return;

        const card = container.querySelector(".card");
        const cardWidth = card.offsetWidth;
        const gap = 11; // match your CSS
        const step = cardWidth + gap;

        const visibleCards = Math.floor(viewport.offsetWidth / step);
        const totalCards = container.children.length;
        const maxIndex = totalCards - visibleCards;

        let currentIndex = 0;

        function updateSlider() {
          container.style.transition = "transform 0.3s ease";
          const offset = currentIndex * step;
          container.style.transform = `translateX(-${offset}px)`;
        }

        rightBtn.addEventListener("click", () => {
          currentIndex++;
          if (currentIndex > maxIndex) {
            currentIndex = 0; // loop back to start
          }
          updateSlider();
        });

        leftBtn.addEventListener("click", () => {
          currentIndex--;
          if (currentIndex < 0) {
            currentIndex = maxIndex; // loop to end
          }
          updateSlider();
        });

        updateSlider();
      });
    </script>
  </body>
</html>
