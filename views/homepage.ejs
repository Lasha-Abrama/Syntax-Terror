<!DOCTYPE html>
<html>
  <head>
    <title>Spotify</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>
  <body>
    <div class="wrapper">
      <%- include('partials/sidebar') %>

      <div class="right">
        <%- include('partials/header') %>

        <main class="main-content">
          <!-- Top Buttons -->
          <div class="filter-buttons">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="music">Music</button>
            <button class="filter-btn" data-filter="podcasts">Podcasts</button>
            <button class="filter-btn" data-filter="audiobooks">
              Audiobooks
            </button>
          </div>

          <!-- Made For You Section -->
          <section class="section made-for-you">
            <h3>Made For You</h3>
            <div class="card-container">
              <% mixes.slice(0, 8).forEach(item => { %> <%-
              include('partials/card', { item }) %> <% }) %>
            </div>
          </section>

          <!-- Your Top Mixes Section -->
          <section class="section top-mixes">
            <h3>Your Top Mixes</h3>
            <div class="card-container">
              <% mixes.slice(8).forEach(item => { %> <%-
              include('partials/card', { item }) %> <% }) %>
            </div>
          </section>

          <!-- Your Favorite Artists Section -->
          <section class="section favorite-artists">
            <h3>Your Favorite Artists</h3>
            <div class="artist-container">
              <!-- <%# favoriteArtists.forEach(artist => { %>
                <%#- include('partials/artist', { artist }) %>
              <%# }) %> -->
            </div>
          </section>
        </main>
      </div>
    </div>

    <%- include('partials/player') %>
  </body>
</html>
